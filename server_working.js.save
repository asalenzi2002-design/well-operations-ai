    coreEngine = CoreEngine.initializeCoreEngine(wells, dnLogs, dnMaster);
    if (!coreEngine) {
      console.warn("[CoreEngine] Initialization returned null, advanced features disabled");
    }
  } catch (error) {
    console.error("[CoreEngine] Failed to initialize:", error);
  }
}
